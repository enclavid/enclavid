package enclavid:disclosure;

interface disclosure {
    use enclavid:types/types.{text-ref};

    /// One consented field surfaced on the applicant's consent
    /// screen and (modulo the label) included in the sealed
    /// disclosure envelope to the consumer.
    ///
    /// Both `key` and `label` are `text-ref`s into the policy's
    /// `prepare-text-refs` dictionary; the host membership-checks
    /// them at every call (unregistered ref → trap, closing the
    /// runtime text-ref-crafting channel).
    ///
    ///   * `key` is the stable machine identifier the consumer SDK
    ///     uses for typed mapping. The host treats it as an opaque
    ///     string and **always shows it raw** on the consent screen.
    ///     Two complementary defences against a policy that tries
    ///     to encode categorical data (country, gender, bucket id,
    ///     ...) into key cardinality:
    ///       (a) Pre-registration in `prepare-text-refs` — the set
    ///           is frozen before any per-session input reaches the
    ///           policy, so a fresh `passport-number-<user-country>`
    ///           can't be minted at evaluate time.
    ///       (b) Visibility on the consent UI — the raw text-ref
    ///           is displayed alongside the resolved label for any
    ///           non-canonical key, so any pre-registered variant
    ///           the policy picks at runtime is staring the user
    ///           in the face before they tap Allow.
    ///     Convention: pick stable, human-readable kebab/snake-case
    ///     names (`passport-number`, `first-name`) for routine
    ///     fields so the consumer SDK can map by literal; unusual
    ///     names trigger the consent UI's "custom" highlight.
    ///   * `label` is the human-readable field name. The host
    ///     resolves it via the policy's text registry into the full
    ///     set of language translations; the frontend picks the
    ///     user's locale. Resolved label is sent to the frontend
    ///     **only** — it never reaches the sealed envelope, closing
    ///     any covert translation channel where non-user-locale
    ///     variants might otherwise smuggle data to the consumer.
    ///
    /// `value` is the policy-supplied data. Sanitised host-side
    /// (control chars / BIDI overrides / zero-width / Unicode-tag
    /// chars stripped, length-bounded to 200 bytes); format is
    /// policy's call.
    record display-field {
        key: text-ref,
        label: text-ref,
        value: string,
    }

    /// Ask the applicant to consent to disclosing the listed fields
    /// to the platform consumer.
    ///
    ///   * `reason` is the purpose-of-use statement shown on the
    ///     consent screen and persisted alongside the disclosure
    ///     entry — bound as part of the user's consent record so
    ///     downstream audit can answer "why was this disclosed?".
    ///   * `requester` is the human-readable name of the party that
    ///     requested this verification (e.g. "Acme Trading"). Shown
    ///     prominently on the consent screen so the applicant knows
    ///     to whom the data is being disclosed — distinguishes the
    ///     consumer (recipient) from the Enclavid platform (which
    ///     runs the check but never sees the data). NOT included in
    ///     the sealed envelope: the consumer authored the policy
    ///     and already knows their own name; including it there
    ///     would just bloat the disclosure ciphertext.
    ///
    /// Both are `text-ref`s into `prepare-text-refs` (host-validates
    /// membership; no default).
    prompt-disclosure: func(
        fields: list<display-field>,
        reason: text-ref,
        requester: text-ref,
    ) -> bool;
}
