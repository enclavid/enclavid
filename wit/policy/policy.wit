package enclavid:policy;

interface policy {
    enum decision {
        approved,
        rejected,
        rejected-retryable,
        review
    }

    variant eval-args {
        %string(string),
        int(s64),
        float(f64),
        %bool(bool),
        null,
    }

    /// Reference to a string declared by `prepare-text-refs`.
    /// Opaque key â€” the host validates membership in the registered
    /// set at every use-site (host fn arg, consent field key/label,
    /// media labels, consent reason) and traps if absent. Format is
    /// also enforced: ASCII `[a-z][a-z0-9_-]{0,127}` so the value is
    /// safe to display raw on the consent screen when it's surfaced
    /// for non-canonical keys. Type alias (not a record) so SDKs can
    /// compose constants cheaply: typically backed by a compile-time
    /// enum that surfaces a `&'static str` per entry.
    type text-ref = string;

    /// One translation row: `value` is the raw human-readable string
    /// in `language`. The host sanitises the value at registration
    /// time (strip control / BIDI / zero-width / Unicode-tag chars,
    /// soft-truncate at 1000 chars) and rejects raw inputs over
    /// 16 KiB (hard cap, second-line guard behind the wasmtime
    /// linear-memory limit on the policy component). `language`
    /// must match a BCP-47-shaped tag (`[A-Za-z][A-Za-z0-9-]{0,15}`).
    record translation {
        language: string,
        value: string,
    }

    /// All translations of one `text-ref`, grouped under its `key`.
    /// One `localized-text` per key â€” this is the structural
    /// uniqueness check at the WIT level (vs. flat list-of-rows
    /// where the same `(key, language)` pair could legally repeat).
    record localized-text {
        key: text-ref,
        translations: list<translation>,
    }

    /// Declaration of one `text-ref` the policy will use at runtime.
    /// Discriminated:
    ///   * `identifier` â€” pure machine key, no human-readable form.
    ///     The host registers it for membership-check purposes only;
    ///     it never goes through a translation table. Typical use:
    ///     `display-field.key` shown raw on the consent screen when
    ///     non-canonical.
    ///   * `localized` â€” a key with its full translation set in one
    ///     block. Resolved to multi-language text host-side when
    ///     assembling UI-bound payloads.
    variant text-decl {
        identifier(text-ref),
        localized(localized-text),
    }

    /// Declare every `text-ref` the policy will pass to host fns at
    /// `evaluate` time (media labels, capture instructions, consent
    /// field keys, consent field labels, consent reasons, ...).
    /// Called by the host exactly once per policy load â€” BEFORE any
    /// per-session input reaches the policy. The frozen set is the
    /// only thing the host accepts as a text-ref afterwards.
    ///
    /// Host enforces at this call:
    ///   * Total decls â‰¤ 4096 (registry memory bound, second line
    ///     behind the wasmtime memory cap).
    ///   * Each key passes the `text-ref` format check.
    ///   * No duplicate keys across `identifier` + `localized`.
    ///   * Inside a `localized` block, no duplicate `language`.
    ///   * Each `translation.value` is sanitised + length-bounded.
    ///   * Each `translation.language` passes the BCP-47 shape check.
    ///
    /// This is the invariant that closes two channels at once:
    ///   * "browser extension scrapes interpolated PII from labels"
    ///     â€” every label is enumerable at audit time.
    ///   * "policy crafts a text-ref at evaluate time based on user
    ///     attributes" â€” the registry is built before policy has
    ///     access to per-session args / clips / anything.
    prepare-text-refs: func() -> list<text-decl>;

    evaluate: func(args: list<tuple<string, eval-args>>) -> decision;
}
