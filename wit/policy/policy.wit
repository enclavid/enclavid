package enclavid:policy;

interface policy {
    enum decision {
        approved,
        rejected,
        rejected-retryable,
        review
    }

    variant eval-args {
        %string(string),
        int(s64),
        float(f64),
        %bool(bool),
        null,
    }

    evaluate: func(args: list<tuple<string, eval-args>>) -> decision;
}
