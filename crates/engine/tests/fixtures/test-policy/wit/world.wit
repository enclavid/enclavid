package enclavid:test-policy@0.1.0;

world policy {
    // Canonical KYC building blocks from the well-known plugin: pre-baked
    // capture flows and `display-field` helpers. Satisfied at /connect via
    // runtime composition — the consumer pins the plugin's `impl_ref` in
    // POST /sessions; the policy carries only these imports.
    import enclavid:well-known/capture@0.1.0;
    import enclavid:well-known/disclosure-fields@0.1.0;

    // Host interfaces. Field labels, capture copy and icons all come from
    // the plugin's own embedded sections, so the policy only resolves its
    // own consent copy via embedded/i18n.
    import enclavid:embedded/i18n@0.1.0;
    import enclavid:disclosure/disclosure@0.1.0;
    import enclavid:form/media@0.1.0;
    export enclavid:policy/policy@0.1.0;
}
