package enclavid:test-policy@0.1.0;

world policy {
    // Canonical KYC building blocks from the well-known plugin: pre-baked
    // capture flows and `display-field` helpers. Satisfied at /connect via
    // runtime composition — the consumer pins the plugin's `impl_ref` in
    // POST /sessions; the policy carries only these imports.
    import enclavid:well-known/capture@0.1.0;
    import enclavid:well-known/disclosure-fields@0.1.0;

    // A second plugin, imported to exercise HYBRID composition: baked
    // into no core, linked at runtime on top of a pre-fused (policy +
    // well-known) core. `tag::get()` resolves a key from the extra
    // plugin's OWN i18n catalog, so its embedded import routes to a
    // distinct twin.
    import enclavid:extra/tag@0.1.0;

    // The vision substrate. preprocess decodes the selfie `clip` into a
    // plugin-owned `decoded-frame`; face-detect locates the `face` in it;
    // face-age reads its crop and estimates. The policy just threads the
    // handles decode → detect → estimate. `enclavid:vision/types` carries the
    // shared `decoded-frame` / `face` vocabulary the policy holds in between.
    import enclavid:preprocess/decode@0.1.0;
    import enclavid:face-detect/detect@0.1.0;
    import enclavid:vision/types@0.1.0;

    // The face-age plugin: a real decoded-frame + face consumer. No embedded
    // catalog of its own → no routing twin.
    import enclavid:face-age/check@0.1.0;

    // Host interfaces. The policy resolves its own consent copy via
    // embedded/i18n; static config comes from `context.props`. Capture and
    // consent are driven by the `action` the policy returns from `handle`
    // (`render(prompt::media)` / `render(prompt::consent-disclosure)`), not
    // by suspending host imports.
    import enclavid:host/embedded-i18n@0.1.0;
    import enclavid:host/session-context@0.1.0;
    export enclavid:policy/policy@0.1.0;
}
